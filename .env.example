# --- Deployment Config (Production only) ---
DOMAIN_NAME=pets.yourdomain.com

# --- Frontend Config ---
# Local dev / Docker local: http://localhost:3000
# Production:               https://pets.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:3000

# --- MongoDB Config ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pets_dev

# --- AWS S3 Config ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-dev-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed if using local AWS profiles
AWS_PROFILE=
